# Local HCP downloads and generated data
data/*
!data/README.md
**/hcp_task/
**/hcp_task.tgz

# Personal staging outputs remain local until the team agrees how to share them
sandbox/*/artifacts_staging/*
!sandbox/*/artifacts_staging/README.md

# Python / Jupyter
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/

# Secrets and local configuration
.env
.env.*
*.pem
credentials*.json

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Personal agent overrides (private; keep shared rules in AGENTS.md)
AGENTS.local.md
.agents.md
**/AGENTS.local.md
**/.agents.md


# Notebook figures live embedded in the .ipynb, not as loose files.
# Ignore both savefig outputs and viewer/preview render duplicates.
sandbox/**/fig*.png
pipeline/*.png
**/_view_*.png

# Standalone interactive 3D brain HTML exports are heavy viewer artifacts
# (nb09 regenerates these in-notebook). Keep any kept copy local, out of git.
sandbox/goutham/*.html

# The submitted abstract PDF is kept local only (it carries author emails on its
# title page); manuscript/abstract.md is the versioned source of the text.
manuscript/*.pdf

# Local scratch / temp (throwaway files, chat figures) — never commit.
tmp/

# Office lock files and app-generated backups (never versioned)
~$*
*.pptx.bak-*
